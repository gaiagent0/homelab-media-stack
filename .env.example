# =============================================================
# homelab-media-stack — Environment Variables
# Copy to: .env  (never commit .env)
# =============================================================

# --- User/group for file ownership ---
PUID=1500
PGID=1500
TZ=Europe/Budapest

# --- Storage paths (inside docker-host LXC) ---
DATA_PATH=/mnt/mediastore/data
DOCKER_VOLUMES=/mnt/mediastore/config

# --- VPN provider (Gluetun) ---
# Variable names must match docker-compose.yml references exactly
VPN_PROVIDER=private internet access
VPN_TYPE=openvpn
OPENVPN_USER=CHANGEME
OPENVPN_PASSWORD=CHANGEME
VPN_REGION=Hungary

# --- Jellyfin ---
JELLYFIN_PORT=8096

# --- Jellystat database ---
# POSTGRES_USER is hardcoded as 'postgres' in the image — do not change
POSTGRES_PASSWORD=CHANGEME_STRONG_PASSWORD
JELLYSTAT_JWT_SECRET=CHANGEME_32_CHARS_MINIMUM_RANDOM_STRING

# --- Wizarr external URL (Cloudflare Tunnel) ---
APP_URL=https://join.yourdomain.com

# --- Homepage widget API keys ---
# Fill these in after the stack is running — get keys from each app's Settings > General
HOMEPAGE_VAR_LXC_IP=10.10.40.32
HOMEPAGE_VAR_JELLYFIN_API_KEY=CHANGEME
HOMEPAGE_VAR_JELLYSEERR_API_KEY=CHANGEME
HOMEPAGE_VAR_RADARR_API_KEY=CHANGEME
HOMEPAGE_VAR_SONARR_API_KEY=CHANGEME
HOMEPAGE_VAR_LIDARR_API_KEY=CHANGEME
HOMEPAGE_VAR_PROWLARR_API_KEY=CHANGEME
HOMEPAGE_VAR_BAZARR_API_KEY=CHANGEME
HOMEPAGE_VAR_QBIT_PASSWORD=CHANGEME