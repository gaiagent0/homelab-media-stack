# homelab-media-stack — environment config
# Copy to .env and fill in your values. Never commit .env!

# ── Paths ────────────────────────────────────────────────────────────────────
DATA_PATH=/mnt/mediastore/data
DOCKER_VOLUMES=/mnt/mediastore/config
ARCHIVE_STORAGE=/mnt/mediastore/archive

# ── User/timezone ─────────────────────────────────────────────────────────────
PUID=1500
PGID=1500
TZ=Europe/Budapest

# ── VPN (Gluetun) ─────────────────────────────────────────────────────────────
VPN_PROVIDER=private internet access
VPN_TYPE=openvpn
OPENVPN_USER=your_pia_username
OPENVPN_PASSWORD=your_pia_password
VPN_REGION=Hungary

# ── Ports ────────────────────────────────────────────────────────────────────
JELLYFIN_PORT=8096

# ── Secrets ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_strong_password
JELLYSTAT_JWT_SECRET=changeme_jwt_secret_min32chars